# PicHost — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

PICHOST_AUTH_JWT_SECRET=change-me-to-a-random-64-char-string

# Storage Backend (optional — defaults to local filesystem)
# Uncomment and configure for RustFS / S3-compatible storage:
# PICHOST_STORAGE_DEFAULT_BACKEND=rustfs
# PICHOST_STORAGE_RUSTFS_ENDPOINT=http://localhost:9000
# PICHOST_STORAGE_RUSTFS_BUCKET=pichost
# PICHOST_STORAGE_RUSTFS_ACCESS_KEY=minioadmin
# PICHOST_STORAGE_RUSTFS_SECRET_KEY=minioadmin
# PICHOST_STORAGE_RUSTFS_REGION=us-east-1
# PICHOST_STORAGE_RUSTFS_PUBLIC_ENDPOINT=https://media.example.com
